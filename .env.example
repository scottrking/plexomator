# Slack Configuration
# Get these from https://api.slack.com/apps after creating your app
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# The channel ID to monitor for movie posts (right-click channel in Slack > View channel details > Copy ID)
MONITORED_CHANNEL_ID=C1234567890

# Radarr Configuration
RADARR_URL=http://localhost:7878
RADARR_API_KEY=your-radarr-api-key-here

# Radarr Settings
# Get these from Radarr Settings
RADARR_ROOT_FOLDER=/movies
RADARR_QUALITY_PROFILE=1

# TMDB Configuration
# Get this from https://www.themoviedb.org/ > Settings > API
TMDB_API_KEY=your-tmdb-api-key-here
